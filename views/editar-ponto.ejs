<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Editar Agendamento - Coleta Seletiva</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('./partials/navbar') %>
  <div class="container">
    <h2>✏️ Alterar Agendamento</h2>

    <form action="/pontos/editar/<%= agendamento.id %>" method="POST" class="form-card">
      <div class="form-group">
        <label for="pontoColetaId">Ponto de Coleta *</label>
        <select id="pontoColetaId" name="pontoColetaId" required>
          <% pontos.forEach(ponto => { %>
            <option value="<%= ponto.id %>" <%= agendamento.PontoColetaId === ponto.id ? 'selected' : '' %>>
              <%= ponto.nomePonto %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="form-group" style="margin-bottom: 15px;">
        <label><strong>Tipos de Resíduo (Selecione quantos desejar) *</strong></label>
        <div style="border: 1px solid #ccc; padding: 10px; border-radius: 5px; background-color: #fff;">
          <% residuos.forEach(res => { %>
            <label style="display: block; cursor: pointer; margin-bottom: 8px;">
              <input type="checkbox" name="residuoId" value="<%= res.id %>"
                <%= agendamento.residuoIdsSelecionados && agendamento.residuoIdsSelecionados.includes(res.id.toString()) ? 'checked' : '' %>>
              <%= res.nomeResiduo %>
            </label>
          <% }) %>
        </div>
      </div>

      <div class="form-group">
        <label for="endereco">Endereço *</label>
        <input type="text" id="endereco" name="endereco"
               value="<%= agendamento.endereco %>" required>
      </div>

      <div class="form-group">
        <label for="dataHora">Data e Hora *</label>
        <input type="datetime-local" id="dataHora" name="dataHora"
               value="<%= new Date(agendamento.dataHora).toISOString().slice(0,16) %>" required>
      </div>

      <div class="form-group" style="margin-bottom: 15px;">
        <label><strong>Status Atual *</strong></label>
        <input type="text" value="<%= agendamento.status %>" disabled 
               style="background-color: #e9ecef; cursor: not-allowed; width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; font-weight: bold;">
        <small style="color: #6c757d; display: block; margin-top: 5px;">🔒 Apenas o administrador pode alterar o status da coleta.</small>
      </div>

      <div class="form-actions" style="margin-top: 20px;">
        <button type="submit" class="btn btn-primary">Salvar Alterações</button>
        <a href="/pontos" class="btn btn-secondary">Voltar</a>
      </div>
    </form>
  </div>
</body>
</html>