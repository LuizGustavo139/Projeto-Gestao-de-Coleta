<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel do Administrador</title>
    <link rel="stylesheet" href="/css/style.css"> 
</head>
<body>
    <div class="navbar">
        <div class="navbar-brand">⚙️ Painel de Administração</div>
        <div class="navbar-links">
            <a href="/auth/logout" class="btn btn-danger" style="text-decoration: none; color: white; background-color: #dc3545; padding: 6px 12px; border-radius: 4px; font-weight: bold;">Sair do Modo Admin</a>
        </div>
    </div>

    <div class="container">
        
        <div class="page-header" style="margin-bottom: 15px;">
            <h2>Painel de Controle</h2>
        </div>

        <div class="cards-row" style="margin-bottom: 40px;">
            <div class="card" style="text-align: center; padding: 30px;">
                <h3 style="margin-top: 0;">📍 Pontos de Coleta</h3>
                <p style="color: #6c757d; margin-bottom: 20px; font-size: 14px;">Crie, edite ou remova os ecopontos disponíveis para os cidadãos no sistema.</p>
                <a href="/pontos-coleta" class="btn btn-primary" style="display: block; width: 100%; box-sizing: border-box;">Gerenciar Pontos</a>
            </div>

            <div class="card" style="text-align: center; padding: 30px;">
                <h3 style="margin-top: 0;">♻️ Tipos de Resíduos</h3>
                <p style="color: #6c757d; margin-bottom: 20px; font-size: 14px;">Cadastre e atualize as categorias de materiais recicláveis aceitos nos pontos.</p>
                <a href="/residuos" class="btn btn-primary" style="display: block; width: 100%; box-sizing: border-box;">Gerenciar Resíduos</a>
            </div>
        </div>

        <hr style="margin-bottom: 30px; border-top: 1px solid #ddd;">

        <div class="page-header">
            <h2>📋 Gestão de Agendamentos</h2>
        </div>

        <div class="tabela-container">
            <table class="tabela">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Solicitado em</th>
                        <th>Usuário</th>
                        <th>Ponto de Coleta</th>
                        <th style="white-space: normal; min-width: 140px;">Tipos de Resíduos</th>
                        <th style="white-space: normal; min-width: 180px;">Endereço do Usuário</th>
                        <th>Data Agendada</th>
                        <th>Status</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (agendamentos && agendamentos.length > 0) { %>
                        <% agendamentos.forEach(agendamento => { %>
                            <tr>
                                <td><strong>#<%= agendamento.id || 'N/A' %></strong></td>
                                
                                <td style="font-size: 13px; color: #555; font-weight: 500;">
                                    <%= agendamento.solicitadoEmFormatado %>
                                </td>

                                <td><%= agendamento.nomeUsuario || (agendamento.User ? agendamento.User.nome : 'Usuário Deletado') %></td>
                                
                                <td><%= agendamento.pontoColeta ? agendamento.pontoColeta.nomePonto : 'Não informado' %></td>
                                
                                <td style="white-space: normal;"><%= agendamento.nomesResiduos || 'Não informado' %></td>
                                
                                <td style="white-space: normal;"><%= agendamento.endereco %></td>
                                
                                <td><%= new Date(agendamento.dataHora).toLocaleString('pt-BR') %></td>
                                
                                <td>
                                    <span class="status-badge status-<%= agendamento.status.toLowerCase().replace(' ', '-') %>">
                                        <%= agendamento.status %>
                                    </span>
                                </td>
                                
                                <td>
                                    <form action="/admin/agendamentos/<%= agendamento.id %>/status" method="POST" style="display: flex; align-items: center; gap: 5px;">
                                        <select name="novoStatus" style="padding: 5px; border: 1px solid #ccc; border-radius: 4px; font-size: 13px; width: auto;">
                                            <option value="Pendente" <%= agendamento.status === 'Pendente' ? 'selected' : '' %>>Pendente</option>
                                            <option value="Aprovado" <%= agendamento.status === 'Aprovado' ? 'selected' : '' %>>Aprovado</option>
                                            <option value="Em Andamento" <%= agendamento.status === 'Em Andamento' ? 'selected' : '' %>>Em Andamento</option>
                                            <option value="Concluído" <%= agendamento.status === 'Concluído' ? 'selected' : '' %>>Concluído</option>
                                            <option value="Cancelado" <%= agendamento.status === 'Cancelado' ? 'selected' : '' %>>Cancelado</option>
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-primary" style="padding: 5px 10px; font-size: 13px; border-radius: 4px; border: none; background-color: #007bff; color: white; cursor: pointer; width: auto;">
                                            Atualizar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="9" class="empty-msg">Nenhum agendamento encontrado no sistema.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>