<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Redefinir Senha - Coleta Seletiva</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <% if (typeof user !== 'undefined' && user) { %>
    <%- include('./partials/navbar') %>
  <% } %>

  <div class="auth-page" style="<%= (typeof user !== 'undefined' && user) ? 'min-height: calc(100vh - 56px);' : '' %>">
    <div class="auth-card">
      <div class="auth-logo">🔒</div>
      <h2>Redefinir Senha</h2>
      <p class="text-muted" style="margin-bottom: 20px; font-size: 0.85rem; line-height: 1.4;">Digite seu e-mail cadastrado e a nova senha para atualizar seu acesso.</p>

      <% if (typeof error !== 'undefined' && error) { %>
        <p class="error-msg" style="text-align: left;"><%= error %></p>
      <% } %>

      <% if (typeof success !== 'undefined' && success) { %>
        <p style="color: #1b5e20; background: #e8f5e9; border: 1px solid #c8e6c9; border-radius: 5px; padding: 9px 14px; margin-bottom: 16px; font-size: 0.9rem; text-align: left;">
          ✅ <%= success %>
        </p>
      <% } %>

      <form action="/auth/alterar-senha" method="POST" class="form-card">
        <div class="form-group">
          <label for="email">Seu E-mail:</label>
          <input type="email" id="email" name="email" placeholder="seu@email.com" required>
        </div>

        <div class="form-group">
          <label for="novaSenha">Nova Senha:</label>
          <input type="password" id="novaSenha" name="novaSenha" placeholder="Mínimo 5 caracteres" minlength="5" required>
        </div>

        <button type="submit" class="btn btn-primary btn-block">Redefinir Senha</button>
      </form>
      
      <div style="margin-top: 20px;">
        <% if (typeof user !== 'undefined' && user) { %>
          <% if (user.isAdmin) { %>
            <a href="/admin/dashboard" class="btn btn-secondary btn-block" style="text-decoration: none; font-weight: bold;">← Voltar para Gestão Admin</a>
          <% } else { %>
            <a href="/pontos" class="btn btn-secondary btn-block" style="text-decoration: none; font-weight: bold;">← Voltar para o Dashboard</a>
          <% } %>
        <% } else { %>
          <a href="/auth/login" class="btn btn-secondary btn-block" style="text-decoration: none; font-weight: bold;">← Voltar para o Login</a>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>