<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Novo Agendamento - Coleta Seletiva</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('./partials/navbar') %>
  
  <div class="container" style="padding-top: 10px;">
    <h2 style="text-align: center; margin-bottom: 24px; font-size: 1.4rem; color: #1b5e20;">📅 Solicitar Novo Agendamento de Coleta</h2>

    <% if (typeof error !== 'undefined' && error) { %>
      <p class="error-msg"><%= error %></p>
    <% } %>

    <form action="/pontos/novo" method="POST" class="form-card" style="max-width: 580px;">
      <div class="form-group">
        <label for="pontoColetaId">1. Ponto de Coleta *</label>
        <select id="pontoColetaId" name="pontoColetaId" required>
          <option value="" disabled selected>Selecione um ponto...</option>
          <% pontos.forEach(ponto => { %>
            <option value="<%= ponto.id %>"><%= ponto.nomePonto %> — <%= ponto.endereco %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label style="font-weight: 600; display: block; margin-bottom: 8px;">2. Tipos de Resíduo (Selecione quantos desejar) *</label>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 10px; padding: 12px; border: 1px solid #ccc; border-radius: 5px; background: #fafafa; max-height: 180px; overflow-y: auto;">
          <% residuos.forEach(res => { %>
            <label style="display: flex; align-items: center; gap: 8px; font-weight: normal; cursor: pointer; margin: 0; font-size: 14px; color: #333;">
              <input type="checkbox" id="res_<%= res.id %>" name="residuoId" value="<%= res.id %>" style="width: auto; margin: 0; cursor: pointer;">
              <%= res.nomeResiduo %>
            </label>
          <% }) %>
        </div>
      </div>

      <div class="form-group">
        <label for="endereco">3. Endereço de Retirada/Descarte *</label>
        <input type="text" id="endereco" name="endereco" placeholder="Ex: Rua das Flores, nº 100" required>
      </div>

      <div class="form-group">
        <label for="dataHora">4. Data e Hora da Coleta *</label>
        <input type="datetime-local" id="dataHora" name="dataHora" required>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">✅ Confirmar Agendamento</button>
        <a href="/pontos" class="btn btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>

  <script>
    document.querySelector('form').addEventListener('submit', function(e) {
      // Busca apenas os checkboxes que estão marcados usando o novo padrão de nome
      const checkboxes = document.querySelectorAll('input[name="residuoId"]:checked');
      
      // Se a quantidade de marcados for zero, barra o envio!
      if (checkboxes.length === 0) {
        e.preventDefault(); // Impede o formulário de ser enviado ao servidor
        alert('⚠️ Opa! Você precisa selecionar pelo menos um tipo de resíduo para realizar o agendamento.');
      }
    });
  </script>
</body>
</html>