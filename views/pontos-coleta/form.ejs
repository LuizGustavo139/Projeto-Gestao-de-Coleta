<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title><%= ponto ? 'Editar' : 'Novo' %> Ponto de Coleta - Coleta Seletiva</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>
  <div class="container">
    
    <h2 style="text-align: center; margin-bottom: 20px;"><%= ponto ? '✏️ Editar Ponto de Coleta' : '➕ Novo Ponto de Coleta' %></h2>

    <% if (erro) { %>
      <p class="error-msg"><%= erro %></p>
    <% } %>

    <form action="/pontos-coleta/<%= ponto ? 'editar/' + ponto.id : 'novo' %>" method="POST" class="form-card">
      <div class="form-group">
        <label for="nomePonto">Nome do Ponto *</label>
        <input type="text" id="nomePonto" name="nomePonto"
               value="<%= ponto ? ponto.nomePonto : '' %>"
               placeholder="Ex: EcoPonto Centro" required>
      </div>
      
      <div class="form-group">
        <label for="endereco">Endereço *</label>
        <input type="text" id="endereco" name="endereco"
               value="<%= ponto ? ponto.endereco : '' %>"
               placeholder="Ex: Rua das Flores, 100" required>
      </div>
      
      <div class="form-group" style="margin-bottom: 15px;">
        <label style="display: block; font-weight: bold; margin-bottom: 8px;">Resíduos Aceitos *</label>
        
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; padding: 12px; border: 1px solid #ccc; border-radius: 4px; background: #fafafa; max-height: 200px; overflow-y: auto;">
          <% if (typeof residuos !== 'undefined' && residuos.length > 0) { %>
            <% residuos.forEach(res => { %>
              <% 
                // Se for edição, verifica se este resíduo específico já estava salvo na string do ponto
                let jaAceita = false;
                if (ponto && ponto.residuosAceitos) {
                  jaAceita = ponto.residuosAceitos.split(', ').map(item => item.trim()).includes(res.nomeResiduo);
                }
              %>
              <label style="display: flex; align-items: center; gap: 8px; font-weight: normal; cursor: pointer; margin: 0; font-size: 14px; color: #333;">
                <input type="checkbox" name="residuosAceitos" value="<%= res.nomeResiduo %>" <%= jaAceita ? 'checked' : '' %> style="cursor: pointer; width: auto; margin: 0;">
                <%= res.nomeResiduo %>
              </label>
            <% }) %>
          <% } else { %>
            <p style="grid-column: span 2; color: #dc3545; font-size: 13px; margin: 0;">Nenhum tipo de resíduo cadastrado no sistema.</p>
          <% } %>
        </div>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Salvar</button>
        <a href="/pontos-coleta" class="btn btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</body>
</html>