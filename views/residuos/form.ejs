<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title><%= residuo ? 'Editar' : 'Novo' %> Resíduo - Coleta Seletiva</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>
  <div class="container">
    <h2><%= residuo ? '✏️ Editar Resíduo' : '➕ Novo Resíduo' %></h2>

    <% if (erro) { %>
      <p class="error-msg"><%= erro %></p>
    <% } %>

    <form action="/residuos/<%= residuo ? 'editar/' + residuo.id : 'novo' %>" method="POST" class="form-card">
      <div class="form-group">
        <label for="nomeResiduo">Nome do Resíduo *</label>
        <input type="text" id="nomeResiduo" name="nomeResiduo"
               value="<%= residuo ? residuo.nomeResiduo : '' %>"
               placeholder="Ex: Plástico" required>
      </div>
      <div class="form-group">
        <label for="descricao">Descrição</label>
        <textarea id="descricao" name="descricao" rows="3"
                  placeholder="Descreva os tipos de materiais aceitos"><%= residuo ? residuo.descricao : '' %></textarea>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Salvar</button>
        <a href="/residuos" class="btn btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</body>
</html>
