<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Dashboard - Coleta Seletiva</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('./partials/navbar') %>

  <div class="container">
    <div class="page-header">
      <h2>Olá, <%= user.nome %>! 👋</h2>
      <a href="/pontos/novo" class="btn btn-primary">📅 Novo Agendamento</a>
    </div>

    <div class="cards-row">
      <div class="card">
        <h3>📍 Pontos de Coleta Disponíveis</h3>
        <ul>
          <% pontos.forEach(ponto => { %>
            <li>
              <strong><%= ponto.nomePonto %></strong><br>
              <span class="text-muted">🗺️ <%= ponto.endereco %></span><br>
              <span class="badge">♻️ <%= ponto.residuosAceitos %></span>
            </li>
          <% }) %>
        </ul>
      </div>

      <div class="card">
        <h3>♻️ Tipos de Resíduos</h3>
        <ul>
          <% residuos.forEach(res => { %>
            <li>
              <strong><%= res.nomeResiduo %></strong>: <%= res.descricao %>
            </li>
          <% }) %>
        </ul>
      </div>
    </div>

    <hr>

    <h3>📋 Meus Agendamentos</h3>
    <table class="tabela">
      <thead>
        <tr>
          <th>Solicitado em</th>
          <th>Nome / Solicitante</th> 
          <th>Ponto de Coleta</th>
          <th>Tipo de Resíduo</th>
          <th>Endereço de Descarte</th>
          <th>Data / Hora do agendamento</th>
          <th>Status</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        <% agendamentos.forEach(agendamento => { %>
          <tr>
            <td style="font-size: 13px; color: #555; font-weight: 500;">
              <%= agendamento.solicitadoEmFormatado %>
            </td>

            <td><strong><%= agendamento.nomeUsuario %></strong></td>
            
            <td><strong><%= agendamento.pontoColeta ? agendamento.pontoColeta.nomePonto : '—' %></strong></td>
            
            <td><%= agendamento.nomesResiduos %></td>
            
            <td><%= agendamento.endereco %></td>

            <td><%= new Date(agendamento.dataHora).toLocaleString('pt-BR') %></td>

            <td>
              <span class="status-badge status-<%= agendamento.status.toLowerCase().replace(' ', '-') %>">
                <%= agendamento.status %>
              </span>
            </td>

            <td>
              <% if (agendamento.status === 'Pendente') { %>
                <a href="/pontos/editar/<%= agendamento.id %>" class="btn btn-sm btn-edit">Editar</a>
                <a href="/pontos/deletar/<%= agendamento.id %>" class="btn btn-sm btn-danger"
                   onclick="return confirm('Cancelar este agendamento?')">Cancelar</a>
              <% } else { %>
                <span style="color: #6c757d; font-style: italic; font-size: 13px; font-weight: bold;">🔒 Finalizado</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
        <% if (agendamentos.length === 0) { %>
          <tr>
            <td colspan="8" class="empty-msg">Você não possui nenhuma coleta agendada no momento.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</body>
</html>